# Skein configuration — copy to `.env` and adjust. All vars are optional;
# Skein runs with sensible defaults derived from your home directory.

# Colon-separated absolute paths Skein scans for project folders containing
# live Claude Code sessions. Defaults to your home directory if unset.
# Example (macOS iCloud + a code dir):
#   SKEIN_SCAN_ROOTS=/Users/you/Library/Mobile Documents/com~apple~CloudDocs:/Users/you/code
SKEIN_SCAN_ROOTS=

# API server port (Hono, on Bun). Default: 5556
# SKEIN_API_PORT=5556

# UI dev server port (Vite). Default: 5555
# SKEIN_UI_PORT=5555
