{
  "name": "skein",
  "version": "0.1.0",
  "description": "A lightweight, read-only companion dashboard for Claude Code — persistent context, session coherence, and multi-project visibility, alongside your native terminal.",
  "license": "MIT",
  "author": "Andrew Blake",
  "type": "module",
  "homepage": "https://github.com/abblake/skein#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/abblake/skein.git"
  },
  "bugs": {
    "url": "https://github.com/abblake/skein/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "dashboard",
    "session-management",
    "developer-tools",
    "bun",
    "hono",
    "react",
    "pai",
    "context"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:ui\"",
    "dev:ui": "vite",
    "dev:server": "bun --watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "heartbeat": "bun scripts/heartbeat-cron.ts",
    "heartbeat:daemon": "bun scripts/heartbeat-cron.ts --daemon",
    "digest": "bun scripts/generate-digests.ts",
    "digest:all": "bun scripts/generate-digests.ts --all"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "hono": "^4.7.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "chokidar": "^4.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
